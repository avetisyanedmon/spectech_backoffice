# Production Environment Configuration for SpecTech Backoffice
# Copy this file and configure for your production environment

# Server Configuration
PORT=5050
NODE_ENV=production

# CORS - Add your production frontend URLs
FRONTEND_ORIGINS=https://spectech-marketplace.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=https://spectech-marketplace.vercel.app,https://your-domain.com

# Trust proxy for production (required for Render, Heroku, etc.)
TRUST_PROXY=true

# Database Configuration - PRODUCTION USES SUPABASE
USE_SUPABASE=true

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here_keep_secret

# SMS Configuration
# Get API ID from: https://sms.ru/?panel=settings
SMS_RU_API_ID=your_sms_ru_api_id
SMS_RU_FROM=SPECTECH

# JWT Configuration
# Generate with: openssl rand -base64 32
JWT_SECRET=your_strong_jwt_secret_min_32_chars
OTP_HASH_PEPPER=your_otp_pepper_secret

# Redis Configuration (Optional - for production OTP storage)
# Example: redis://default:password@redis-host:6379
REDIS_URL=redis://your-redis-url

# Test Accounts (Optional - only enable if needed for testing in production)
# WARNING: Security risk if enabled in production!
# ENABLE_TEST_ACCOUNTS_IN_PROD=0
# TEST_AUTH_PHONE=+79990000000
# TEST_AUTH_CODE=111111
# TEST_AUTH_ROLE=customer
