PORT=5050
FRONTEND_ORIGINS=http://localhost:4028
DATABASE_PATH=./data/app.db

# Database Configuration
# Set USE_SUPABASE=true to use Supabase (PostgreSQL) instead of SQLite
USE_SUPABASE=false

# Supabase Configuration (required when USE_SUPABASE=true)
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SMS Configuration
SMS_RU_API_ID=your_sms_ru_api_id
# Sender name (optional): set after creating at https://sms.ru/?panel=senders. If unset, first approved sender is used.
# SMS_RU_FROM=SPECTECH

# Dev bypass: use test phone numbers to skip real SMS
# TEST_AUTH_PHONE=+79990000000
# TEST_AUTH_CODE=111111
# TEST_AUTH_ROLE=customer
# TEST_AUTH_PHONE_2=+79990000001
# TEST_AUTH_CODE_2=222222
# TEST_AUTH_ROLE_2=contractor
# Enable test accounts in production (set to 1 to enable, useful for testing)
# ENABLE_TEST_ACCOUNTS_IN_PROD=1

# JWT Configuration
JWT_SECRET=replace_with_strong_secret
OTP_HASH_PEPPER=optional_extra_secret

# Optional Redis, OTP storage falls back to in-memory when absent.
# REDIS_URL=redis://localhost:6379
